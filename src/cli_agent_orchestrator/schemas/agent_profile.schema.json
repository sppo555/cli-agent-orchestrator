{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CAO Agent Profile Frontmatter",
  "description": "Validates the YAML frontmatter of a CAO agent profile .md file.",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,64}$",
      "description": "Unique agent identifier (filesystem-safe)."
    },
    "description": {
      "type": "string",
      "description": "Brief description of the agent's purpose."
    },
    "role": {
      "type": "string",
      "description": "Agent role. Built-in values: supervisor, developer, reviewer. Custom roles are also supported via settings.json."
    },
    "provider": {
      "type": "string",
      "description": "Provider override (e.g. claude_code, kiro_cli, codex)."
    },
    "allowedTools": {
      "type": "array",
      "items": {"type": "string"},
      "description": "CAO tool vocabulary allowlist."
    },
    "mcpServers": {
      "type": "object",
      "description": "MCP server configurations for additional tools.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "command": {"type": "string"},
          "args": {"type": "array", "items": {"type": "string"}},
          "env": {"type": "object", "additionalProperties": {"type": "string"}},
          "timeout": {"type": "integer"}
        },
        "required": ["command"]
      }
    },
    "tools": {
      "type": "array",
      "items": {"type": "string"}
    },
    "toolAliases": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "toolsSettings": {
      "type": "object"
    },
    "model": {
      "type": "string"
    },
    "permissionMode": {
      "type": "string",
      "enum": ["default", "acceptEdits", "plan", "auto", "bypassPermissions"]
    },
    "native_agent": {
      "type": "string"
    },
    "codexProfile": {
      "type": "string",
      "minLength": 1
    },
    "codexConfig": {
      "type": "object"
    },
    "hermesProfile": {
      "type": "string",
      "minLength": 1
    },
    "skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "prompt": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": {"type": "string"}
    },
    "hooks": {
      "type": "object"
    },
    "useLegacyMcpJson": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
